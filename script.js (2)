document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('live-search-input');
    const resultsContainer = document.getElementById('live-search-results');
    const resultsList = document.getElementById('search-results-list');
    
    const dataStore = [
        { title: "Dashboard Overview", url: "/dashboard" },
        { title: "Product Catalog Management", url: "/products/manage" },
        { title: "User Settings and Profile", url: "/settings/profile" },
        { title: "Analytics and Reports", url: "/reports/analytics" },
        { title: "Help Documentation & FAQs", url: "/help" },
        { title: "Invoice History", url: "/billing/invoices" },
        { title: "API Configuration", url: "/settings/api" },
        { title: "Data Model Visualization", url: "/model/view" }
    ];
    
    const displayResults = (results) => {
        resultsList.innerHTML = '';
        
        if (results.length === 0) {
            resultsContainer.style.display = 'none';
            return;
        }
        
        results.forEach(item => {
            const listItem = document.createElement('li');
            const link = document.createElement('a');
            link.href = item.url;
            link.textContent = item.title;
            // Prevent sidebar close when clicking a search result link
            link.onclick = (e) => {
                e.preventDefault();
                console.log(`Navigating to: ${item.url}`);
                // Optional: Hide sidebar after selection
                toggleSidebar();
            };
            listItem.appendChild(link);
            resultsList.appendChild(listItem);
        });
        
        resultsContainer.style.display = 'block';
    };
    
    const fetchResults = (query) => {
        const filteredResults = dataStore.filter(item => item.title.toLowerCase().includes(query.toLowerCase()));
        return filteredResults;
    };
    
    searchInput.addEventListener('input', (e) => {
        const query = e.target.value.trim();
        
        if (query.length > 1) {
            const results = fetchResults(query);
            displayResults(results);
        } else {
            resultsContainer.style.display = 'none';
        }
    });
    
    searchInput.addEventListener('blur', () => {
        setTimeout(() => {
            if (!resultsContainer.contains(document.activeElement)) {
                resultsContainer.style.display = 'none';
            }
        }, 150);
    });
    
    searchInput.addEventListener('focus', (e) => {
        const query = e.target.value.trim();
        if (query.length > 1) {
            const results = fetchResults(query);
            displayResults(results);
        }
    });
    
    document.addEventListener('click', (e) => {
        if (!searchInput.contains(e.target) && !resultsContainer.contains(e.target)) {
            resultsContainer.style.display = 'none';
        }
    });
});

