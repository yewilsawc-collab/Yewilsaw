function formatGeminiResponse(rawText) {
    // Regex to find ```language [code] ```
    const codeRegex = /```(\w*)\n([\s\S]*?)```/g;
    
    return rawText.replace(codeRegex, (match, lang, code) => {
        const id = `code-${Math.random().toString(36).substr(2, 9)}`;
        return `
            <div class="code-block-container">
                <div class="code-header">
                    <span>${lang || 'code'}</span>
                    <button class="copy-btn" onclick="copyCode('${id}')">Copy</button>
                </div>
                <pre><code id="${id}">${escapeHtml(code.trim())}</code></pre>
            </div>
        `;
    });
}

