/* Stream multiple chunks sequentially */

async function streamBotChunks(chunks) {
  hideThinking();
  const out = document.getElementById('output');
  const msg = document.createElement('div');
  msg.className = 'msg bot';
  out.appendChild(msg);

  let chunkIndex = 0;

  
  function streamChunk(chunkText) {
    
    // Detect code block
    
    const codeMatch = chunkText.match(/```(\w*)\n([\s\S]*?)```/);
    if (codeMatch) {
      const lang = codeMatch[1] || 'code';
      const code = codeMatch[2].trim();
      msg.innerHTML += mdParser(chunkText); 
      
      // render with syntax highlighting
      
      out.scrollTop = out.scrollHeight;
      chunkIndex++;
      if (chunkIndex < chunks.length) {
        msg.innerHTML += "<br><br>";
        setTimeout(() => streamChunk(chunks[chunkIndex]), 500);
      }
      return;
    }

    // Otherwise stream word-by-word
    
    const words = chunkText.split(' ');
    let i = 0;
    const interval = setInterval(() => {
      msg.innerHTML += (i > 0 ? ' ' : '') + words[i];
      i++;
      out.scrollTop = out.scrollHeight;
      if (i >= words.length) {
        clearInterval(interval);
        chunkIndex++;
        if (chunkIndex < chunks.length) {
          msg.innerHTML += "<br><br>";
          setTimeout(() => streamChunk(chunks[chunkIndex]), 500);
        }
      }
    }, 80);
  }

  streamChunk(chunks[0]);
}


