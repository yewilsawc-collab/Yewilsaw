function toggleCanvas(show) {
document.getElementById('container').classList.toggle('canvas-active', show);
}

function updateCanvas(code) {
const frame = document.getElementById('canvas-frame');
let content = code.trim();
if (!content.toLowerCase().includes('<html')) {
content = `<!DOCTYPE html><html><head><meta charset="UTF-8"><style>body{font-family:sans-serif;padding:20px;background:#fff;color:#000;}</style></head><body>${content}</body></html>`;
}
frame.srcdoc = content;
toggleCanvas(true);
}


function highlight(code) {
if (!code) return "";

return code
// 1. Strings (Handle quotes carefully)
.replace(/(['"`])(.*?)\1/g, '<span class="syn-str">$1$2$1</span>')
// 2. Comments (Single line)
.replace(/\/\/.*/g, '<span class="syn-com">$&</span>')
// 3. Keywords
.replace(/\b(const|let|var|if|else|for|while|return|function|class|async|await|import|export|from|new|try|catch|finally|default|case|switch)\b/g,
'<span class="syn-key">$1</span>')
// 4. Numbers
.replace(/\b(\d+)\b/g, '<span class="syn-num">$1</span>')
// 5. Function Calls/Definitions
.replace(/\b(\w+)(?=\()/g, '<span class="syn-def">$1</span>');
}

function mdParser(text) {
if (!text) return "";

// Step 1: Handle Code Blocks separately to avoid global escaping issues
const parts = text.split(/(```[\s\S]*?```)/g);

return parts.map(part => {
if (part.startsWith('```')) {
const match = part.match(/```(\w*)\n([\s\S]*?)```/);
if (!match) return "";

const lang = match[1] || 'code';
const rawCode = match[2].trim();

// Escape HTML only for the raw code before highlighting
const escapedCode = rawCode
.replace(/&/g, "&amp;")
.replace(/</g, "&lt;")
.replace(/>/g, "&gt;");

const canRender = ['html', 'javascript', 'css', 'svg', 'react'].includes(lang.toLowerCase()) || lang === '';

return `<pre><div class="code-lang">${lang}</div>
<div style="position:absolute;top:5px;right:10px;display:flex;gap:10px;z-index:10;">
${canRender ? `<div class="code-btn" onclick="updateCanvas(this.parentElement.parentElement.querySelector('code').innerText)">PREVIEW</div>` : ''}
<div class="code-btn" onclick="copySnippet(this)">COPY</div>
</div>
<code>${highlight(escapedCode)}</code></pre>`;
} else {
// Step 2: Handle regular text (Escape and handle line breaks)
return part
.replace(/&/g, "&amp;")
.replace(/</g, "&lt;")
.replace(/>/g, "&gt;")
.replace(/\n/g, '<br>');
}
}).join('');
}


function render(role, text, file = null) {
const out = document.getElementById('output');
const div = document.createElement('div');
div.className = `msg ${role === 'user' ? 'user' : 'bot'}`;

if (file && file.data) {
const img = document.createElement('img');
img.src = file.data;
img.style = "max-width:260px; border-radius:12px; margin-bottom:12px; border: 1px solid var(--border);";
div.appendChild(img);
}

const content = document.createElement('div');
content.innerHTML = mdParser(text);
div.appendChild(content);
out.appendChild(div);
out.scrollTop = out.scrollHeight;

if (role === 'bot') {
const codeMatch = text.match(/```(?:html|)\n([\s\S]*?)```/i);
if (codeMatch) updateCanvas(codeMatch[1]);
}
}

async function handleSend() {
    if (isRequesting) return;
    const field = document.getElementById('user-input');
    const text = field.value.trim();
    const key = localStorage.getItem('el_key');
    const model = localStorage.getItem('el_model') || 'gemini-2.5-flash'; // Updated to 1.5 stable

    if (!key) { alert("Please set your API Key in Settings."); return; }
    if (!text && !stagedFile) return;

    isRequesting = true;
    document.getElementById('working-status').style.display = 'block';

    // 1. Render User Message
    render('user', text, stagedFile);
    const currentFile = stagedFile;
    clearFile();
    field.value = '';
    field.style.height = '46px';

    // 2. Update Thread History
    let thread = chatHistory.find(t => t.id === activeThreadId);
    if (!thread) { createNewThread(); thread = chatHistory[0]; }
    thread.messages.push({ role: 'user', content: text, file: currentFile });

    // 3. Prepare Streaming UI
    // We create the bot message container manually so we can update it in real-time
    const output = document.getElementById('output');
    const botMsgDiv = document.createElement('div');
    botMsgDiv.className = 'msg bot';
    const textContainer = document.createElement('div');
    textContainer.className = 'markdown-body'; // Or your specific class
    botMsgDiv.appendChild(textContainer);
    output.appendChild(botMsgDiv);
    
    // Add a temporary typing indicator
    const loader = document.createElement('div');
    loader.className = 'typing';
    loader.innerHTML = `<div class="dot"></div><div class="dot"></div><div class="dot"></div>`;
    textContainer.appendChild(loader);
    output.scrollTop = output.scrollHeight;

    let fullReply = "";

    try {
        // Use streamGenerateContent endpoint
        const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/${model}:streamGenerateContent?alt=sse&key=${key}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                contents: thread.messages.map(m => ({
                    role: m.role === 'user' ? 'user' : 'model',
                    parts: [
                        { text: m.content || "Uploaded image context" },
                        ...(m.file ? [{ inline_data: { mime_type: m.file.type, data: m.file.data.split(',')[1] } }] : [])
                    ]
                })),
                systemInstruction: { parts: [{ text: "You are Elementa" }] }
})
});

if (!response.ok) {
const errData = await response.json();
throw new Error(errData.error?.message || "Stream connection failed");
}

const reader = response.body.getReader();
const decoder = new TextDecoder();
let buffer = "";

// Remove loader before starting stream text
loader.remove();

while (true) {
const { done, value } = await reader.read();
if (done) break;

buffer += decoder.decode(value, { stream: true });

// Gemini SSE format sends blocks of JSON.
// We need to extract the text from the candidates in each chunk.
const lines = buffer.split('\n');
buffer = lines.pop(); // Keep partial line in buffer

for (const line of lines) {
if (!line.startsWith('data: ')) continue;

try {
const jsonStr = line.replace('data: ', '');
const data = JSON.parse(jsonStr);
const content = data.candidates?.[0]?.content?.parts?.[0]?.text || "";

if (content) {
fullReply += content;
// Update UI - using innerHTML/textContent or your markdown parser
// If you have a markdown renderer (like marked.js), use it here:
// textContainer.innerHTML = marked.parse(fullReply);
textContainer.textContent = fullReply;

// Auto-scroll
output.scrollTop = output.scrollHeight;
}
} catch (e) {
console.error("Error parsing stream chunk", e);
}
}
}

// 4. Finalize
thread.messages.push({ role: 'model', content: fullReply });
if (thread.title === "New Chat") thread.title = text.slice(0, 30) || "Image Analysis";

// Final render to apply syntax highlighting or markdown if needed
// render('bot', fullReply); // You might need to adjust your render logic to replace the temp div
saveData();

} catch (e) {
if (loader) loader.remove();
textContainer.innerHTML = `<span style="color: var(--error)">Error: ${e.message}</span>`;
} finally {
isRequesting = false;
document.getElementById('working-status').style.display = 'none';
}
}


function saveData() {
localStorage.setItem('el_v11_chats', JSON.stringify(chatHistory));
localStorage.setItem('el_v11_active', activeThreadId);
renderHistory();
}

function createNewThread() {
const id = 't_' + Date.now();
chatHistory.unshift({ id, title: 'New Chat', messages: [] });
activeThreadId = id;
document.getElementById('output').innerHTML = '';
toggleCanvas(false);
saveData();
closeDrawers();
}

function switchThread(id) {
activeThreadId = id;
const thread = chatHistory.find(t => t.id === id);
document.getElementById('output').innerHTML = '';
if (thread) thread.messages.forEach(m => render(m.role, m.content, m.file));
saveData();
closeDrawers();
}

function renderHistory() {
const list = document.getElementById('thread-list');
list.innerHTML = chatHistory.map(t => `<div style="padding:15px; border-bottom:1px solid #222; cursor:pointer; font-size:14px; ${t.id === activeThreadId ? 'color:var(--accent)' : ''}" onclick="switchThread('${t.id}')">${t.title}</div>`).join('');
}

