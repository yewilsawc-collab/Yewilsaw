    document.documentElement.style.setProperty('--font-scale', size);
    settings.fontSize = size;
    localStorage.setItem('FONT_SIZE', size); // Persist font size immediately
    
    document.querySelectorAll('.font-btn').forEach(b => b.classList.remove('active'));
    
    if (btn) {
        btn.classList.add('active');
    } else {
        const targetBtn = Array.from(document.querySelectorAll('.font-btn')).find(b => {
            const attr = b.getAttribute('onclick');
            // Safely check for the size in the onclick attribute
            return attr && attr.includes(`setFontSize(${size},`);
        });
        if (targetBtn) targetBtn.classList.add('active');
    }
};


